{
  "permissions": {
    "allow": [
      "Bash(archetipo config *)",
      "Bash(archetipo spec *)",
      "Bash(archetipo task *)",
      "Bash(golangci-lint run *)",
      "Bash(pnpm test)",
      "Bash(pnpm test:coverage)",
      "Bash(go tool cover *)",
      "Bash(pnpm exec *)",
      "Bash(pnpm lint *)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(pnpm test *)",
      "Bash(make web:test)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ryoku/repos/archetipo-test/.claude/hooks/web-check.sh",
            "timeout": 60,
            "statusMessage": "Checking web lint & types…"
          },
          {
            "type": "command",
            "command": "/home/ryoku/repos/archetipo-test/.claude/hooks/go-check.sh",
            "timeout": 60,
            "statusMessage": "Checking Go lint & build…"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "playwright@claude-plugins-official": true
  }
}
