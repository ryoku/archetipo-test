{
  "permissions": {
    "allow": [
      "Bash(archetipo config *)",
      "Bash(archetipo spec *)",
      "Bash(archetipo task *)",
      "Bash(golangci-lint run *)",
      "Bash(pnpm test)",
      "Bash(pnpm test:coverage)",
      "Bash(go tool cover *)",
      "Bash(pnpm exec *)",
      "Bash(pnpm lint *)",
      "Bash(go build *)",
      "Bash(go test *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // \"\"'); case \"$f\" in *.go) cd /home/ryoku/repos/release-control-plane && golangci-lint run \"$f\" 2>&1 || true;; *.ts|*.tsx) npx eslint \"$f\" 2>&1 || true;; esac",
            "timeout": 60,
            "statusMessage": "Linting…"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "playwright@claude-plugins-official": true
  }
}
