# Application server port
SERVER_PORT=8081

# Global default regex for tag-convention validation (applied when a product has no override set).
# TAG_CONVENTION_DEFAULT=^v\d+\.\d+\.\d+$

# PostgreSQL — matches the docker-compose.yml dev database
DATABASE_URL=postgresql://kubegate:kubegate@localhost:5433/kubegate

# Keycloak OIDC
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=kubegate
KEYCLOAK_CLIENT_ID=kubegate-server
KEYCLOAK_CLIENT_SECRET=dev-secret
# OIDC_ISSUER_URL is derived from KEYCLOAK_URL + KEYCLOAK_REALM at startup.
# Override here only when using a non-Keycloak OIDC provider.
# OIDC_ISSUER_URL=http://localhost:8080/realms/kubegate

# Gitops mock repository (bare git repo created by `make dev`)
GITOPS_REPO_PATH=./tmp/gitops-mock.git
# URL form consumed by the gitops writer and workload discovery (file:// remote for local dev).
# NOTE: $(pwd) expands correctly when sourced by bash (Makefile: set -a && . ./.env).
# It does NOT expand in dotenv libraries or Docker --env-file. Replace with an absolute path in those contexts.
GITOPS_REPO_URL=file://$(pwd)/tmp/gitops-mock.git

# Deployment status cache TTL in seconds (default: 60)
# STATUS_CACHE_TTL_SECONDS=60

# Frontend OIDC (Vite)
VITE_OIDC_ISSUER_URL=http://localhost:8080/realms/kubegate
VITE_OIDC_CLIENT_ID=kubegate-frontend

# SONAR_TOKEN=<your-sonarqube-user-token>

# GCR / Artifact Registry — required for tag listing (US-020)
# Set to the path of a GCP service account JSON key file.
# On GKE, Workload Identity is used automatically when this is unset.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json